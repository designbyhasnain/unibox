# =============================================================================
# UNIBOX — Environment Variables Template
# =============================================================================
# Copy this file to .env (for local dev) or set in Vercel Dashboard
# (Project → Settings → Environment Variables)
#
# For PRODUCTION on Vercel, update GOOGLE_REDIRECT_URI to your live domain.
# =============================================================================

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

# Pooled connection — used at runtime (fast, handles many concurrent requests)
DATABASE_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:6543/postgres?pgbouncer=true&sslmode=require&connection_limit=5&pool_timeout=10"

# Direct connection — used by Prisma for migrations only (bypasses PgBouncer)
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"

# Public vars — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<YOUR_ANON_KEY>

# ⚠️ NEVER expose this in the browser — Vercel: set as "Server" environment only
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SERVICE_ROLE_KEY>

# ─── Encryption ───────────────────────────────────────────────────────────────
# 64-char hex string used to encrypt stored OAuth tokens at rest.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ If you rotate this key, existing encrypted tokens will break.
ENCRYPTION_KEY=<64_CHAR_HEX_STRING>

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs → Credentials → OAuth 2.0 Client IDs

GOOGLE_CLIENT_ID=<YOUR_CLIENT_ID>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<YOUR_CLIENT_SECRET>

# LOCAL:       http://localhost:3000/api/auth/google/callback
# PRODUCTION:  https://your-domain.vercel.app/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google Cloud Pub/Sub topic for Gmail push notifications (optional)
# Format: projects/<GCP_PROJECT_ID>/topics/<TOPIC_NAME>
GOOGLE_PUBSUB_TOPIC=projects/<GCP_PROJECT_ID>/topics/unibox-topic

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ Use a strong random value in production — never use a guessable string.
NEXTAUTH_SECRET=<STRONG_RANDOM_STRING>
NEXTAUTH_URL=http://localhost:3000

# ─── App URL ─────────────────────────────────────────────────────────────────
# Base URL for email tracking pixels and click tracking
# Required in production for correct tracking URLs
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ─── Vercel Cron ─────────────────────────────────────────────────────────────
# Secret used to authenticate Vercel Cron job requests.
# Vercel auto-sets this when you add cron jobs — or generate your own:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ─── Default User ────────────────────────────────────────────────────────────
# Temporary: used as a fallback user ID until proper session-based auth is implemented.
# Set this to the UUID of the admin/default user in your Supabase users table.
# TODO: Remove once OAuth state parameter propagates user identity properly.
DEFAULT_USER_ID=<YOUR_USER_UUID>
NEXT_PUBLIC_DEFAULT_USER_ID=<YOUR_USER_UUID>
