{
    "framework": "nextjs",
    "buildCommand": "prisma generate && next build",
    "installCommand": "npm install",
    "regions": [
        "iad1"
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store"
                }
            ]
        }
    ],
    "functions": {
        "app/api/sync/route.ts": {
            "maxDuration": 60
        },
        "app/api/webhook/route.ts": {
            "maxDuration": 30
        },
        "app/api/auth/(.*)/route.ts": {
            "maxDuration": 30
        }
    }
}