{
    "framework": "nextjs",
    "buildCommand": "next build --experimental-build-mode=compile || true",
    "installCommand": "npm install",
    "regions": [
        "iad1"
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store"
                }
            ]
        }
    ],
    "functions": {
        "app/api/sync/route.ts": {
            "maxDuration": 60
        },
        "app/api/webhooks/gmail/route.ts": {
            "maxDuration": 30
        },
        "app/api/auth/google/callback/route.ts": {
            "maxDuration": 30
        },
        "app/api/campaigns/process/route.ts": {
            "maxDuration": 60
        },
        "app/api/cron/process-webhooks/route.ts": {
            "maxDuration": 30
        },
        "app/api/cron/renew-gmail-watches/route.ts": {
            "maxDuration": 60
        },
        "app/api/sync/poll/route.ts": {
            "maxDuration": 30
        },
        "app/api/sync/health/route.ts": {
            "maxDuration": 60
        },
        "app/api/cron/sync-imap/route.ts": {
            "maxDuration": 60
        },
        "app/api/mine-templates/route.ts": {
            "maxDuration": 60
        }
    },
    "crons": [
        {
            "path": "/api/mine-templates",
            "schedule": "0 3 * * 1"
        }
    ]
}